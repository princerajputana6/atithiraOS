# MongoDB
MONGODB_URI=
MONGODB_URI_TEST=

# Auth.js
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# MFA (AES-256 key, 32 random bytes hex-encoded)
MFA_ENCRYPTION_KEY=

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ImageKit
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Inngest — event bus for domain events (welcome email, workflow automation).
# LOCAL DEV: leave the keys BLANK and run the dev server in a second terminal:
#   npx inngest-cli@latest dev
# The app auto-uses dev mode outside production, so events flow to the local
# dev server (http://localhost:8288) instead of Inngest Cloud. Setting a key
# here does NOT enable cloud locally — that's what INNGEST_DEV=false is for.
# PRODUCTION: set both keys from the Inngest dashboard (cloud mode is automatic
# when NODE_ENV=production).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
# INNGEST_DEV=false   # force cloud mode locally (only if testing real keys)

# AI Copilot (optional — leave blank to keep the ₹0 setup; Copilot degrades gracefully)
# Default model is claude-haiku-4-5 (cheapest). Override with AI_MODEL, e.g. claude-opus-4-8.
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5

# Razorpay (optional — leave blank to keep the ₹0 setup; checkout degrades gracefully)
# Webhook secret is set in the Razorpay dashboard when registering the
# /api/v1/billing/webhook endpoint URL.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Tenant website hosting (optional — leave blank to keep tenant sites reachable
# only at the in-app "/site/{slug}" path). Set to your apex domain (e.g.
# atithira.com) once wildcard DNS ("*.atithira.com") and a wildcard TLS cert
# point at this app, and a published page becomes live at
# "{tenantSlug}.atithira.com" automatically — see apps/web/src/middleware.ts.
NEXT_PUBLIC_ROOT_DOMAIN=